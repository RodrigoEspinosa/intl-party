{
  "name": "@intl-party/cli",
  "version": "1.2.0",
  "description": "Command-line interface for IntlParty - validation, extraction, and management tools",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "intl-party": "./dist/cli.js",
    "ip": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format cjs",
    "dev": "tsup src/cli.ts src/index.ts --format cjs --dts --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "cli",
    "i18n",
    "internationalization",
    "validation",
    "extraction",
    "typescript"
  ],
  "author": "RodrigoEspinosa",
  "license": "MIT",
  "homepage": "https://github.com/RodrigoEspinosa/intl-party#readme",
  "bugs": {
    "url": "https://github.com/RodrigoEspinosa/intl-party/issues"
  },
  "dependencies": {
    "@intl-party/core": "workspace:*",
    "commander": "^14.0.0",
    "chalk": "^5.4.0",
    "chokidar": "^4.0.0",
    "glob": "^11.0.0",
    "fs-extra": "^11.3.4",
    "ora": "^8.2.0",
    "inquirer": "^12.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "eslint": "^8.57.1",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RodrigoEspinosa/intl-party.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
