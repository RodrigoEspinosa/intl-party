{
  "name": "@intl-party/eslint-plugin",
  "version": "1.2.0",
  "description": "ESLint plugin for IntlParty - detect hardcoded strings and enforce i18n best practices",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "i18n",
    "internationalization",
    "typescript",
    "hardcoded-strings"
  ],
  "author": "RodrigoEspinosa",
  "license": "MIT",
  "homepage": "https://github.com/RodrigoEspinosa/intl-party#readme",
  "bugs": {
    "url": "https://github.com/RodrigoEspinosa/intl-party/issues"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.58.2",
    "fs-extra": "^11.3.4"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@typescript-eslint/rule-tester": "^8.58.2",
    "eslint": "^8.57.1",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RodrigoEspinosa/intl-party.git",
    "directory": "packages/eslint-plugin"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
