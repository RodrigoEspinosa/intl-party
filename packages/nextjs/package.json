{
  "name": "@intl-party/nextjs",
  "version": "1.3.0",
  "description": "Next.js integration for IntlParty - App Router and Pages Router support with SSR/SSG",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client-exports.d.ts",
      "import": "./dist/client-exports.mjs",
      "require": "./dist/client-exports.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./webpack-plugin": {
      "types": "./dist/webpack-plugin.d.ts",
      "require": "./dist/webpack-plugin.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format cjs,esm --dts --external next,react,react-dom,@formatjs/intl-localematcher,chokidar && tsup src/client-exports.ts --format cjs,esm --dts --external next,react,react-dom && tsup src/webpack-plugin.ts --format cjs --dts --external child_process,path,fs,chokidar",
    "dev": "tsup --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "nextjs",
    "next",
    "i18n",
    "internationalization",
    "typescript",
    "app-router",
    "pages-router",
    "ssr",
    "ssg"
  ],
  "author": "RodrigoEspinosa",
  "license": "MIT",
  "homepage": "https://github.com/RodrigoEspinosa/intl-party#readme",
  "bugs": {
    "url": "https://github.com/RodrigoEspinosa/intl-party/issues"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.3",
    "@intl-party/core": "workspace:*",
    "@intl-party/react": "workspace:*",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "eslint": "^8.57.1",
    "jsdom": "^29.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RodrigoEspinosa/intl-party.git",
    "directory": "packages/nextjs"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
