{
  "name": "@intl-party/core",
  "version": "1.3.0",
  "description": "Core internationalization library with type-safe translations and advanced locale detection",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "typescript",
    "localization",
    "translations"
  ],
  "author": "RodrigoEspinosa",
  "license": "MIT",
  "homepage": "https://github.com/RodrigoEspinosa/intl-party#readme",
  "bugs": {
    "url": "https://github.com/RodrigoEspinosa/intl-party/issues"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^8.57.1",
    "intl-messageformat": "^10.7.0",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "typescript": ">=4.9.0",
    "intl-messageformat": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "intl-messageformat": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RodrigoEspinosa/intl-party.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
